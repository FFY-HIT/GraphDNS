// ==========================================
// 1. 类型定义 (Type Definitions)
// ==========================================
.type ServerID <: symbol
.type Domain   <: symbol
.type RType    <: symbol
.type Content  <: symbol
.type TTL      <: number

// ==========================================
// 2. 输入数据定义 (Input Schema)
// ==========================================
.decl ZoneRecord(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
.input ZoneRecord(IO="stdin")

// ==========================================
// 3. 基础辅助视图 (Helpers)
// ==========================================

.decl AllNames(name: Domain)
AllNames(n) :- ZoneRecord(_, _, n, _, _, _).
AllNames(as(d, Domain)) :-
    ZoneRecord(_, _, _, t, _, d),
    (t = "CNAME"; t = "DNAME"; t = "NS").

.decl DotScan(name: Domain, i: number)
DotScan(n, 0) :- AllNames(n).
DotScan(n, i + 1) :-
    DotScan(n, i),
    i < strlen(n),
    substr(n, i, 1) != ".".

.decl FirstDot(name: Domain, pos: number)
FirstDot(n, pos) :-
    DotScan(n, pos),
    substr(n, pos, 1) = ".".

.decl ParentOf(parent: Domain, child: Domain)
ParentOf(parent, child) :-
    AllNames(child),
    FirstDot(child, pos),
    pos < strlen(child) - 1,
    parent = substr(child, pos + 1, strlen(child) - pos - 1).

.decl IsDescendant(child: Domain, ancestor: Domain)
IsDescendant(c, p) :- ParentOf(p, c).
IsDescendant(c, a) :-
    ParentOf(p, c),
    IsDescendant(p, a).

.decl ZoneApex(zone: Domain)
ZoneApex(z) :-
    ZoneRecord(_, z, z, "SOA", _, _).

.decl BelongsToZone(name: Domain, zone: Domain)
BelongsToZone(n, z) :-
    ZoneApex(z),
    (n = z ; IsDescendant(n, z)).

.decl InBailiwick(ns: Domain, zone: Domain)
InBailiwick(ns, z) :-
    ZoneApex(z),
    (ns = z ; IsDescendant(ns, z)).


// ==========================================
// 3.x 影子记录检测与纯化记录集
// ==========================================

// In-bailiwick glue records:
// A/AAAA records in the same zone whose owner is the target of a non-apex NS record.
.decl GlueRecord(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
GlueRecord(s, z, n, t, ttl, d) :-
    ZoneRecord(s, z, owner, "NS", _, ns_content),
    owner != z,
    n = as(ns_content, Domain),
    InBailiwick(n, z),
    ZoneRecord(s, z, n, t, ttl, d),
    (t = "A"; t = "AAAA").

// NS shadowing:
// Ordinary parent-zone records strictly below a delegated zone cut are shadowed.
// In-bailiwick glue records are retained because they support delegation.
.decl OccNS(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
OccNS(s, z, n, t, ttl, d) :-
    ZoneRecord(s, z, n, t, ttl, d),
    ZoneRecord(s, z, cut, "NS", _, _),
    cut != z,
    IsDescendant(n, cut),
    !GlueRecord(s, z, n, t, ttl, d).

// DNAME shadowing:
// Ordinary records strictly below a DNAME owner are shadowed.
.decl OccD(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
OccD(s, z, n, t, ttl, d) :-
    ZoneRecord(s, z, n, t, ttl, d),
    ZoneRecord(s, z, owner, "DNAME", _, _),
    t != "DNAME",
    IsDescendant(n, owner).

// Unified shadow predicate.
.decl IsShadow(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
IsShadow(s, z, n, t, ttl, d) :-
    OccNS(s, z, n, t, ttl, d).
IsShadow(s, z, n, t, ttl, d) :-
    OccD(s, z, n, t, ttl, d).

// Purified record set R*.
.decl RClean(server: ServerID, zone: Domain, name: Domain, type: RType, ttl: TTL, data: Content)
RClean(s, z, n, t, ttl, d) :-
    ZoneRecord(s, z, n, t, ttl, d),
    !IsShadow(s, z, n, t, ttl, d).


// ==========================================
// 3.y 基于 RClean 的全局辅助视图
// ==========================================

.decl GlobalRecord(zone: Domain, name: Domain, type: RType, data: Content)
GlobalRecord(z, n, t, d) :-
    RClean(_, z, n, t, _, d).

.decl DomainExists(name: Domain)
DomainExists(n) :-
    GlobalRecord(_, n, _, _).

.decl CNAME_Edge(src: Domain, dst: Domain)
CNAME_Edge(src, as(dst, Domain)) :-
    GlobalRecord(_, src, "CNAME", dst).

.decl ExplicitRecord(name: Domain)
ExplicitRecord(n) :-
    RClean(_, _, n, _, _, _).

.decl EmptyNonTerminal(name: Domain)
EmptyNonTerminal(n) :-
    ParentOf(n, c),
    ExplicitRecord(c),
    !ExplicitRecord(n).

EmptyNonTerminal(n) :-
    ParentOf(n, c),
    EmptyNonTerminal(c),
    !ExplicitRecord(n).

.decl NodeExists(name: Domain)
NodeExists(n) :-
    ExplicitRecord(n).

NodeExists(n) :-
    EmptyNonTerminal(n).

.decl WildcardRecord(encloser: Domain)
WildcardRecord(e) :-
    RClean(_, _, w, _, _, _),
    match("^\\*\\..*$", w),
    e = substr(w, 2, strlen(w) - 2).

.decl CoveredByWildcard(query: Domain, encloser: Domain)
CoveredByWildcard(q, e) :-
    AllNames(q),
    WildcardRecord(e),
    ParentOf(e, q),
    !NodeExists(q).

.decl Resolvable(name: Domain)
Resolvable(n) :-
    NodeExists(n).

Resolvable(n) :-
    CoveredByWildcard(n, _).

.decl DNAME_Edge(src: Domain, dst: Domain)
DNAME_Edge(src, dst) :-
    AllNames(src),
    RClean(_, _, owner, "DNAME", _, target_content),
    target = as(target_content, Domain),
    IsDescendant(src, owner),
    len_s = strlen(src),
    len_o = strlen(owner),
    prefix = substr(src, 0, len_s - len_o),
    dst = cat(prefix, target).

.decl AliasEdge(src: Domain, dst: Domain)
AliasEdge(s, d) :-
    CNAME_Edge(s, d).

AliasEdge(s, d) :-
    DNAME_Edge(s, d).

.decl CNAME_Path(src: Domain, dst: Domain)
CNAME_Path(src, dst) :-
    AliasEdge(src, dst).

CNAME_Path(src, final) :-
    CNAME_Path(src, mid),
    AliasEdge(mid, final),
    src != final.

.decl Rewrite_Terminal(src: Domain, final: Domain)
Rewrite_Terminal(src, final) :-
    CNAME_Path(src, final),
    !AliasEdge(final, _).


// ==========================================
// 4. 属性验证规则 (Verification Rules)
// ==========================================

// ------------------------------------------
// 1. Delegation Consistency
// ------------------------------------------
.decl Error_DelegationConsistency(parent: Domain, child: Domain, ns: Content, msg: symbol)
.output Error_DelegationConsistency

.decl ParentNS(parent: Domain, child: Domain, ns: Content)
ParentNS(p, c, ns) :-
    RClean(_, p, c, "NS", _, ns),
    p != c.

.decl ChildNS(child: Domain, ns: Content)
ChildNS(c, ns) :-
    RClean(_, c, c, "NS", _, ns).

// 父区有、子区没有
Error_DelegationConsistency(p, c, ns, "NS set mismatch between parent and child") :-
    ParentOf(p, c),
    ParentNS(p, c, ns),
    !ChildNS(c, ns).

// 子区有、父区没有
Error_DelegationConsistency(p, c, ns, "NS set mismatch between parent and child") :-
    ParentOf(p, c),
    ParentNS(p, c, _),
    (
        (ParentNS(p, c, ns), !ChildNS(c, ns))
        ;
        (ChildNS(c, ns), !ParentNS(p, c, ns))
    ).

.decl NSRequiresCheck(ns: Domain, parent: Domain, child: Domain)

// 来自父域授权的 in-bailiwick NS
NSRequiresCheck(ns, p, c) :-
    ParentOf(p, c),
    ParentNS(p, c, ns_content),
    ns = as(ns_content, Domain),
    InBailiwick(ns, c).

// 来自子域 apex 声明但不在父域授权中的 in-bailiwick NS
NSRequiresCheck(ns, p, c) :-
    ParentOf(p, c),
    ChildNS(c, ns_content),
    ns = as(ns_content, Domain),
    InBailiwick(ns, c),
    !ParentNS(p, c, ns_content).

Error_DelegationConsistency(parent, child, as(ns, Content), "Inconsistent A/AAAA records for NS") :-
    NSRequiresCheck(ns, parent, child),
    (
        (RClean(_, parent, ns, "A", _, _), !RClean(_, child, ns, "A", _, _))
        ;
        (RClean(_, child, ns, "A", _, _), !RClean(_, parent, ns, "A", _, _))
        ;
        (RClean(_, parent, ns, "A", _, ip_parent), RClean(_, child, ns, "A", _, ip_child), ip_parent != ip_child)
        ;
        (RClean(_, parent, ns, "AAAA", _, _), !RClean(_, child, ns, "AAAA", _, _))
        ;
        (RClean(_, child, ns, "AAAA", _, _), !RClean(_, parent, ns, "AAAA", _, _))
        ;
        (RClean(_, parent, ns, "AAAA", _, ip_parent), RClean(_, child, ns, "AAAA", _, ip_child), ip_parent != ip_child)
    ).


// ------------------------------------------
// 2. Finding all aliases
// ------------------------------------------
.decl Info_AliasChain(src: Domain, canonical: Domain)
.output Info_AliasChain

Info_AliasChain(src, dst) :-
    CNAME_Path(src, dst).


// ------------------------------------------
// 3. Lame Delegation
// ------------------------------------------
.decl Error_LameDelegation(child: Domain, ns_server: Content, msg: symbol)
.output Error_LameDelegation

.decl HasSOA(server: ServerID, zone: Domain)
HasSOA(s, z) :-
    RClean(s, z, z, "SOA", _, _).

Error_LameDelegation(child, ns, "NS server not authoritative") :-
    ParentOf(parent, child),
    ParentNS(parent, child, ns),
    ns_id = as(ns, ServerID),
    !HasSOA(ns_id, child).


// ------------------------------------------
// 4. Missing Glue Records
// ------------------------------------------
.decl Error_MissingGlueRecords(child: Domain, ns_server: Domain, msg: symbol)
.output Error_MissingGlueRecords

Error_MissingGlueRecords(c, ns, "Missing glue for in-bailiwick NS") :-
    ParentOf(p, c),
    ParentNS(p, c, ns_content),
    ns = as(ns_content, Domain),
    InBailiwick(ns, c),
    !RClean(_, p, ns, "A", _, _),
    !RClean(_, p, ns, "AAAA", _, _).


// ------------------------------------------
// 5. Cyclic Zone Dependency
// ------------------------------------------
.decl Error_CyclicZoneDependency(domain: Domain, server: Domain, msg: symbol)
.output Error_CyclicZoneDependency

.decl NSDepends(server1: Domain, server2: Domain, domain: Domain)
NSDepends(svr1, svr2, dmn) :-
    RClean(svr1_id, _, dmn, "NS", _, ns_content),
    svr1 = as(svr1_id, Domain),
    svr2 = as(ns_content, Domain),
    svr1 != svr2.

.decl NSReachable(server1: Domain, server2: Domain, domain: Domain)
NSReachable(svr1, svr2, dmn) :-
    NSDepends(svr1, svr2, dmn).

NSReachable(svr1, svr3, dmn) :-
    NSReachable(svr1, svr2, dmn),
    NSDepends(svr2, svr3, dmn).

Error_CyclicZoneDependency(domain, server, "Cyclic NS dependency detected") :-
    NSReachable(server, server, domain).


// ------------------------------------------
// 6. Rewrite Loop
// ------------------------------------------
.decl Error_RewriteLoop(name: Domain, msg: symbol)
.output Error_RewriteLoop

Error_RewriteLoop(n, "Rewrite loop detected") :-
    CNAME_Path(n, n).


// ------------------------------------------
// 7. Response Consistency
// ------------------------------------------
.decl Error_ResponseInconsistency(zone: Domain, name: Domain, type: RType, s1: ServerID, s2: ServerID)
.output Error_ResponseInconsistency

Error_ResponseInconsistency(z, n, t, s1, s2) :-
    RClean(s1, z, n, t, _, data1),
    RClean(s2, z, n, t, _, data2),
    s1 != s2,
    data1 != data2.


// ------------------------------------------
// 8. Rewrite Blackholing
// ------------------------------------------
.decl Error_RewriteBlackhole(src: Domain, target: Domain, msg: symbol)
.output Error_RewriteBlackhole

// CNAME blackholing
Error_RewriteBlackhole(src, target, "CNAME target points to configured domain but is not resolvable") :-
    CNAME_Edge(src, target),
    BelongsToZone(target, zone),
    !Resolvable(target).

// DNAME blackholing
Error_RewriteBlackhole(owner, target, "DNAME target points to configured domain but is not resolvable") :-
    RClean(_, _, owner, "DNAME", _, target_content),
    target = as(target_content, Domain),
    BelongsToZone(target, zone),
    !Resolvable(target).


// ------------------------------------------
// 9. Zero Time To Live
// ------------------------------------------
.decl Error_ZeroTTL(server: ServerID, name: Domain, type: RType)
.output Error_ZeroTTL

Error_ZeroTTL(s, n, t) :-
    RClean(s, _, n, t, ttl, _),
    ttl = 0.


// ------------------------------------------
// 10. Query Exceeds Maximum Length
// ------------------------------------------
.decl Error_QueryExceedsMaximumLength(src: Domain, rewritten: Domain, new_length: number)
.output Error_QueryExceedsMaximumLength

.decl DNAMERecords(zone: Domain, target: Domain)
DNAMERecords(zone, as(target, Domain)) :-
    GlobalRecord(zone, zone, "DNAME", target).

.decl AllDomains(name: Domain)
AllDomains(zone) :-
    GlobalRecord(zone, _, _, _).

AllDomains(name) :-
    GlobalRecord(_, name, _, _).

AllDomains(src) :-
    CNAME_Edge(src, _).

AllDomains(target) :-
    CNAME_Edge(_, target).

.decl DNAMECheck(query: Domain, zone: Domain, target: Domain)
DNAMECheck(query, zone, target) :-
    AllDomains(query),
    DNAMERecords(zone, target),
    IsDescendant(query, zone).

.decl DNAMELength(query: Domain, target: Domain, length: number)
DNAMELength(query, target, strlen(dst)) :-
    DNAME_Edge(query, dst),
    target = dst.

Error_QueryExceedsMaximumLength(query, target, length) :-
    DNAMELength(query, target, length),
    length > 255.
